{
	"files.exclude": {
		"**/.git": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/CVS": true,
		"**/.DS_Store": true,
		"**/Thumbs.db": true,
		"**/.expo": true,
		"**/.expo-shared": true,
		"**/.idea": true,
		"**/.nuxt": true,
		"dist": true,
		".vscode": true,
		"yarn.lock": true,
		"node_modules": true,
		"prisma/__generated__": true
	},
	"hide-files.files": ["dist", ".vscode", "yarn.lock", "node_modules"],
	"search.exclude": {
		"prisma/__generated__": true,
		"node_modules": true
	},
	"typescript.validate.exclude": ["prisma/__generated__/**", "node_modules/**"]
}
